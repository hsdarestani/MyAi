generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }
enum UserStatus { active blocked }
enum LedgerType { TOPUP ADMIN_ADJUSTMENT RESERVATION RESERVATION_RELEASE USAGE_CHARGE REFUND PAYMENT_FAILED }
enum TaskType { chat image video }
enum UsageStatus { pending completed failed refunded }
enum JobStatus { pending processing completed failed canceled refunded }
enum PaymentStatus { pending successful failed rejected }
enum PaymentReceiptStatus { pending approved rejected }
model User { id String @id @default(cuid()) telegramId String @unique username String? firstName String? lastName String? languageCode String? phone String? walletBalance Int @default(0) status UserStatus @default(active) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt lastActiveAt DateTime? costConfirmationThreshold Int? costConfirmationEnabled Boolean @default(true) ledger WalletLedger[] payments Payment[] usages AIUsage[] jobs AIJob[] paymentReceipts PaymentReceipt[] }
model Admin { id String @id @default(cuid()) email String @unique passwordHash String role String @default("owner") createdAt DateTime @default(now()) updatedAt DateTime @updatedAt ledger WalletLedger[] audits AuditLog[] }
model WalletLedger { id String @id @default(cuid()) userId String type LedgerType amount Int balanceBefore Int balanceAfter Int description String metadata Json? createdAt DateTime @default(now()) createdByAdminId String? user User @relation(fields:[userId], references:[id]) admin Admin? @relation(fields:[createdByAdminId], references:[id]) @@index([userId, createdAt]) }
model PaymentReceipt { id String @id @default(cuid()) userId String telegramFileId String? telegramMessageId String? claimedAmount Int? approvedAmount Int? status PaymentReceiptStatus @default(pending) note String? adminNote String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt reviewedAt DateTime? reviewedByAdminId String? metadata Json? user User @relation(fields:[userId], references:[id]) @@index([status, createdAt]) @@index([userId, createdAt]) }
model Payment { id String @id @default(cuid()) userId String provider String amount Int status PaymentStatus @default(pending) paymentUrl String? externalReference String? metadata Json? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt user User @relation(fields:[userId], references:[id]) }
model AIUsage { id String @id @default(cuid()) userId String taskType TaskType status UsageStatus @default(pending) userPromptPreview String internalProvider String? internalModel String? estimatedCost Int? reservedAmount Int? finalUserCharge Int? providerCost Int? grossMargin Int? usageMetadata Json? errorMessage String? confirmationRequired Boolean @default(false) confirmed Boolean @default(false) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt user User @relation(fields:[userId], references:[id]) @@index([taskType, createdAt]) }
model AIJob { id String @id @default(cuid()) userId String taskType TaskType status JobStatus @default(pending) provider String? model String? externalJobId String? prompt String resultUrl String? reservedAmount Int? finalCost Int? errorMessage String? metadata Json? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt user User @relation(fields:[userId], references:[id]) }
model PricingConfig { id String @id @default(cuid()) taskType TaskType @unique minCharge Int fixedBaseFee Int @default(0) markupMultiplier Float @default(2) highCostThreshold Int @default(10000) maxWithoutConfirmation Int @default(10000) roundingStep Int @default(500) enabled Boolean @default(true) updatedAt DateTime @updatedAt }
model AIRouteConfig { id String @id @default(cuid()) taskType TaskType @unique provider String model String fallbackProvider String? fallbackModel String? enabled Boolean @default(true) metadata Json? updatedAt DateTime @updatedAt }
model Setting { key String @id value Json updatedAt DateTime @updatedAt }
model AuditLog { id String @id @default(cuid()) adminId String? action String entityType String entityId String? metadata Json? createdAt DateTime @default(now()) admin Admin? @relation(fields:[adminId], references:[id]) }
